# =============================================================================
# Industrial Knowledge Brain - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (pick ONE, system auto-fallbacks in order shown)
# =============================================================================

# Option 1: Anthropic Claude (PAID - Best Quality)
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option 2: Groq (FREE TIER - Very Fast, Recommended for hackathon)
# Get free key from: https://console.groq.com
# Uses Llama 3.1 70B - excellent quality, fast inference
GROQ_API_KEY=your_groq_api_key_here

# Option 3: Ollama (LOCAL - Completely Free)
# Install from: https://ollama.ai
# Run: ollama pull llama3.1 && ollama serve
# No API key needed!
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# =============================================================================
# Embeddings (for vector search)
# =============================================================================
VOYAGE_API_KEY=your_voyage_api_key_here

# =============================================================================
# ChromaDB (for vector storage)
# =============================================================================
CHROMADB_PATH=./data/chromadb
CHROMADB_COLLECTION=opsbrain_chunks
